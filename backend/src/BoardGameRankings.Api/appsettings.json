{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "Origins": ["http://localhost:5173", "http://localhost:4173"]
  },
  "BggApi": {
    "BaseUrl": "https://boardgamegeek.com",
    "BearerToken": ""
  }
}
